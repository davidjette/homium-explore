{
  "name": "homium-fund-model",
  "version": "0.1.0",
  "description": "Homium Fund Model API — fund simulation engine, housing data, and pro forma PDF generation",
  "main": "dist/api/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/api/server.ts",
    "build": "tsc",
    "prestart": "npx tsc",
    "start": "node dist/api/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx db/seed/seed.ts",
    "generate:county-paths": "tsx scripts/generate-county-paths.ts",
    "generate:fips-lookup": "tsx scripts/generate-fips-lookup.ts"
  },
  "dependencies": {
    "@sparticuz/chromium": "^143.0.4",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "pg": "^8.13.0",
    "pptxgenjs": "^4.0.1",
    "puppeteer-core": "^24.37.5",
    "resend": "^6.9.2",
    "sharp": "^0.33.5",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.3",
    "@types/topojson-client": "^3.1.5",
    "puppeteer": "^24.37.5",
    "supertest": "^7.2.2",
    "topojson-client": "^3.1.0",
    "tsx": "^4.19.0",
    "us-atlas": "^3.0.1",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
